<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        Title="AUBR - مركز التحكم التكتيكي" Height="750" Width="1250" Background="#0F0F12">

    <Window.Resources>
        <Style x:Key="TacticalButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1D"/>
            <Setter Property="Foreground" Value="Cyan"/>
            <Setter Property="BorderBrush" Value="#00FFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00FFFF"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#333" BorderThickness="1" CornerRadius="5" Margin="5">
            <Grid>
                <helix:HelixViewport3D x:Name="Viewport" ZoomExtentsWhenLoaded="True" ShowFrameRate="True" CameraRotationMode="Trackball">
                    <helix:DefaultLights/>
                    <helix:BoxVisual3D x:Name="InterceptorModel" Width="0.6" Length="0.6" Height="0.2" Fill="Lime"/>
                    <helix:BoxVisual3D x:Name="TargetModel" Width="0.6" Length="0.6" Height="0.2" Fill="Red"/>
                    <helix:GridLinesVisual3D Width="1000" Length="1000" Thickness="0.1" Fill="Gray"/>
                </helix:HelixViewport3D>

                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="20">
                    <TextBlock Text="SYSTEM STATUS: ACTIVE" Foreground="Lime" FontSize="12" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtDistance" Text="DISTANCE: 0.0m" Foreground="White" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Column="1" Margin="5">
            <TextBlock Text="بث الكاميرا المباشر" Foreground="Cyan" Margin="0,0,0,10" FontSize="16" FontWeight="Bold"/>

            <Border x:Name="CameraArea" BorderBrush="Cyan" BorderThickness="2" Height="220" CornerRadius="3" Background="#111" 
                    MouseDown="CameraFeed_MouseDown" MouseMove="CameraArea_MouseMove">
                <Canvas x:Name="TargetingCanvas" ClipToBounds="True">
                    <TextBlock Text="Waiting for AI Vision Feed..." Foreground="#444" Canvas.Top="100" Canvas.Left="50"/>
                    <Image x:Name="CameraFeed" Stretch="Uniform" Width="{Binding ElementName=TargetingCanvas, Path=ActualWidth}" Height="{Binding ElementName=TargetingCanvas, Path=ActualHeight}"/>

                    <Ellipse x:Name="MouseReticle" Width="30" Height="30" Stroke="Yellow" StrokeThickness="2" Visibility="Hidden">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="ReticleTransform"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Canvas>
            </Border>

            <TextBlock Text="مقترح الذكاء الاصطناعي:" Foreground="Yellow" Margin="0,20,0,5" FontWeight="Bold"/>
            <Border Background="#222" CornerRadius="5" Padding="15">
                <TextBlock x:Name="TxtSuggestion" Text="بانتظار تحليل بيانات الهدف..." Foreground="White" TextWrapping="Wrap" FontSize="13" Height="60"/>
            </Border>

            <Separator Margin="0,20" Background="#333"/>
            <TextBlock Text="الأوامر التكتيكية" Foreground="White" Margin="0,0,0,15" FontSize="14"/>

            <Button Content="دفع جانبي (Lateral)" Tag="LATERAL_NUDGE" Click="BtnCommand_Click" Style="{StaticResource TacticalButtonStyle}" Margin="0,5"/>
            <Button Content="ضغط علوي (Prop Wash)" Tag="TOP_DOWN_PRESSURE" Click="BtnCommand_Click" Style="{StaticResource TacticalButtonStyle}" Margin="0,5"/>
            <Button Content="تعمية بصرية (Blind)" Tag="VISUAL_BLINDING" Click="BtnCommand_Click" Style="{StaticResource TacticalButtonStyle}" Margin="0,5"/>
            <Button x:Name="BtnAutoEscort" Content="تفعيل المرافقة الآلية" Tag="ESCORT" Click="BtnCommand_Click" Background="#2ECC71" Foreground="Black" FontWeight="Bold" Margin="0,20" Height="45"/>
        </StackPanel>
    </Grid>
</Window>
